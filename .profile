# Set default editor and visual tool
export VISUAL="nvim"
export EDITOR="nvim"

# Export path for rust binaries
export CARGO_HOME="/home/udeyx/.local/lib/rust_packages"
export PATH="$CARGO_HOME:$PATH"
export PATH="$CARGO_HOME/bin:$PATH"

# Export path for nodejs binaries
export NPM_HOME="/home/udeyx/.local/lib/node_packages"
export PATH="$NPM_HOME:$PATH"

# Export path for nodejs binaries
export PNPM_HOME="/home/udeyx/.local/lib/node_packages"
export PATH="$PNPM_HOME:$PATH"

# Export path for go binaries
export GOPATH="/home/udeyx/.local/lib/go_packages"
export PATH="$GOPATH:$PATH"

# Config locale
export LANG="en_US.utf8"

# Export path for some local binaries
export PATH="/home/udeyx/.local/bin:$PATH"

